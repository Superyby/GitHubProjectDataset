APP_NAME=GitHub Project Dataset
ENV=dev
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=postgresql+psycopg://postgres:your_password@host/github_project_dataset

GITHUB_TOKEN=
GITHUB_PER_PAGE=100
GITHUB_MAX_PAGES_PER_QUERY=2
GITHUB_DAILY_REPO_LIMIT=1000

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_ENABLED=false

SCHEDULER_ENABLED=false
SCHEDULER_HOUR=3
SCHEDULER_MINUTE=0

AUTH_TOKEN_EXPIRE_HOURS=168
EMAIL_CODE_EXPIRE_MINUTES=10
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
